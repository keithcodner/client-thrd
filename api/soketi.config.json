{
  "debug": true,
  "host": "0.0.0.0",
  "port": 6001,
  "appManager": {
    "array": {
      "apps": [
        {
          "id": "thrd-app",
          "key": "thrd-app-key",
          "secret": "thrd-app-secret",
          "maxConnections": 100,
          "enableClientMessages": true,
          "enabled": true,
          "maxBackendEventsPerSecond": 100,
          "maxClientEventsPerSecond": 100,
          "maxReadRequestsPerSecond": 100
        }
      ]
    }
  },
  "cors": {
    "credentials": true,
    "origin": ["*"],
    "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
  }
}
