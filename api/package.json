{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "soketi": "soketi start --config=soketi.config.json",
        "laravel": "php artisan serve",
        "dev:all": "concurrently -n soketi,laravel,vite -c cyan,magenta,yellow \"npm run soketi\" \"npm run laravel\" \"npm run dev\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}